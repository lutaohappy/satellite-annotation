#!/bin/sh
# Maven Wrapper Script
# Auto-generated - runs Maven with project-specified version

MAVEN_VERSION=3.9.6
MAVEN_HOME="${HOME}/.m2/wrapper/dists/apache-maven-${MAVEN_VERSION}"
MAVEN_URL="https://dlcdn.apache.org/maven/maven-${MAVEN_VERSION}/${MAVEN_VERSION}/binaries/apache-maven-${MAVEN_VERSION}-bin.tar.gz"

if [ ! -d "$MAVEN_HOME" ]; then
    echo "Downloading Maven ${MAVEN_VERSION}..."
    mkdir -p "${HOME}/.m2/wrapper/dists"
    curl -sL "$MAVEN_URL" | tar xz -C "${HOME}/.m2/wrapper/dists"
fi

exec "$MAVEN_HOME/bin/mvn" "$@"
